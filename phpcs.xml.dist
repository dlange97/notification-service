<?xml version="1.0"?>
<ruleset name="notification-service coding standard">
  <description>PSR-12 checks for notification-service.</description>
  <rule ref="PSR12"/>
  <file>src</file>
  <file>tests</file>
  <exclude-pattern>vendor/*</exclude-pattern>
  <exclude-pattern>var/*</exclude-pattern>
</ruleset>
